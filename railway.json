{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksArch": "amd64",
    "buildCommand": "npm install --ignore-scripts --no-optional"
  },
  "deploy": {
    "startCommand": "node backend/server.js",
    "healthcheckPath": "/",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ALWAYS"
  }
}